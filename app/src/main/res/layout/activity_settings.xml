<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/text_primary_light"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Real-time speech translation powered by Gemini Live"
            android:textColor="@color/text_secondary_light"
            android:textSize="11sp" />

        <!-- CONNECTION -->
        <TextView
            style="@style/SectionTitle"
            android:text="@string/section_connection" />

        <LinearLayout style="@style/SettingsCard"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemini API Key"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/apiKeyEdit"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/edit_text_bg"
                    android:hint="@string/api_key_hint"
                    android:inputType="textPassword"
                    android:paddingHorizontal="10dp"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/showKeyBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/edit_text_bg"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="Show"
                    android:textColor="@color/text_primary_light"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="API Base URL"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/apiBaseEdit"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edit_text_bg"
                android:hint="@string/api_base_hint"
                android:inputType="textUri"
                android:paddingHorizontal="10dp"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/translate_to"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/langSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edit_text_bg"
                android:paddingHorizontal="10dp" />
        </LinearLayout>

        <!-- AUDIO -->
        <TextView
            style="@style/SectionTitle"
            android:text="@string/section_audio" />

        <LinearLayout style="@style/SettingsCard"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/audio_source"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/sourceSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/edit_text_bg"
                android:paddingHorizontal="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/playback_volume"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/volumeSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:max="100" />

            <CheckBox
                android:id="@+id/echoCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/echo_target"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- APPEARANCE -->
        <TextView
            style="@style/SectionTitle"
            android:text="@string/section_appearance" />

        <LinearLayout style="@style/SettingsCard"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/font_size"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/fontSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:max="46"
                android:progress="14" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/bg_opacity"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/opacitySlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:max="95"
                android:progress="60" />

            <CheckBox
                android:id="@+id/showOriginalCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/show_original"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ADVANCED -->
        <TextView
            style="@style/SectionTitle"
            android:text="@string/section_advanced" />

        <LinearLayout style="@style/SettingsCard"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/system_prompt"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/promptEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/edit_text_bg"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:padding="10dp"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/cancelBtn"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/cancel" />

            <Button
                android:id="@+id/saveBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/save" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
